# =============================================================================
# Root .dockerignore — applies to all multi-context builds
# (backend, intelligence_agent, and ingestion all use context: .)
# =============================================================================

# Version control
.git
.gitignore

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Node.js
frontend/node_modules/
frontend/.next/
frontend/.turbo/

# Rust
runner/target/

# Scala / sbt
ingestion/target/
ingestion/project/target/
ingestion/.bloop/

# Go
scrapers/vendor/

# Docker (prevent recursive builds)
**/Dockerfile
**/.dockerignore

# Documentation (not needed in images)
docs/
*.md
LICENSE

# Environment files (secrets)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Misc
*.exe
*.log
*.tmp
