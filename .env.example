# ── Infrastructure Passwords ──────────────────────────────────────────────────
# Used by docker-compose.yml for local instances
NEO4J_PASSWORD=your_secure_neo4j_password_here
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_secure_mongo_password_here

# ── News Ingestion ────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_URL=https://newsapi.org/v2/everything

# ── MongoDB Atlas (Production) ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.hx8bcjh.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=intelligence_db

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── ChromaDB Cloud ────────────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_SSL=true
CHROMA_API_KEY=your_chroma_cloud_api_key_here
CHROMA_TENANT=your_chroma_tenant_here
CHROMA_DATABASE=supply-chain-db
CHROMA_COLLECTION=supply_chain_intel

# ── Neo4j Aura (cloud) ────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j

# ── OpenAI (LangGraph LLM node) ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Go Scraper tuning ─────────────────────────────────────────────────────────
SCALA_HUB_ADDR=localhost:9090
WORKER_CONCURRENCY=5
PAYLOAD_BUFFER_SIZE=200
SHUTDOWN_GRACE_SECONDS=15
DIAL_TIMEOUT_SECONDS=10
SEND_TIMEOUT_SECONDS=5
MAX_SEND_RETRIES=3

# ── Scala Hub tuning ──────────────────────────────────────────────────────────
GRPC_PORT=9090
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHROMA_BATCH_SIZE=10
