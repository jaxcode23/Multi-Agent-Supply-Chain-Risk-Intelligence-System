# ==============================================================================
# Shadow Network - Environment Configuration
# ==============================================================================
# Copy this file to .env and replace placeholder values before running.
# ==============================================================================

# ── Infrastructure Passwords ──────────────────────────────────────────────────
# Used by docker-compose.yml for local instances
NEO4J_PASSWORD=neo4j1234
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=supplychain1234

# ── News Ingestion ────────────────────────────────────────────────────────────
NEWS_API_KEY=
NEWS_API_URL=https://newsapi.org/v2/everything

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local Docker MongoDB
MONGO_URI=mongodb://admin:supplychain1234@mongo:27017/?authSource=admin
MONGO_DB_NAME=intelligence_db

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── ChromaDB Cloud ────────────────────────────────────────────────────────────
CHROMA_HOST=api.trychroma.com
CHROMA_SSL=true
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=supply-chain-db
CHROMA_COLLECTION=supply_chain_intel

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Local Docker Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# ── Gemini (LangGraph LLM node) ──────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Go Scraper Tuning ─────────────────────────────────────────────────────────
SCALA_HUB_ADDR=localhost:9090
WORKER_CONCURRENCY=5
PAYLOAD_BUFFER_SIZE=200
SHUTDOWN_GRACE_SECONDS=15
DIAL_TIMEOUT_SECONDS=10
SEND_TIMEOUT_SECONDS=5
MAX_SEND_RETRIES=3

# ── Scala Hub Tuning ──────────────────────────────────────────────────────────
GRPC_PORT=9090
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHROMA_BATCH_SIZE=10